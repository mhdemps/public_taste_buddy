# Optional — only for production static hosting (Vercel, Netlify, …).
# Deploy `server/index.js` somewhere (e.g. Render), then set this to that service URL with no trailing slash.
# Rebuild the frontend after changing this (Vite inlines env at build time).
# VITE_API_ORIGIN=https://your-api-name.onrender.com

# Optional — only if you must bypass the Vite dev proxy: point the browser at the API directly
# (cross-origin; `server` must return CORS headers; prefer `npm run dev` with default `/api` proxy).
# VITE_API_ORIGIN=http://127.0.0.1:3001
