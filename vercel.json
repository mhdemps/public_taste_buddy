{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "handle": "filesystem" },
    {
      "source": "/api$",
      "destination": "/api/tb-route?tbpath="
    },
    {
      "source": "/api/(?!tb-route)(.*)",
      "destination": "/api/tb-route?tbpath=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "includeFiles": "data/**,server/**",
      "maxDuration": 30
    }
  }
}
